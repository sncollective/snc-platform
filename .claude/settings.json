{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "extraKnownMarketplaces": {
    "nklisch-skills": {
      "source": { "source": "github", "repo": "nklisch/skills", "ref": "f861a56510d3e29ecf23f3d3dc9c2b02177b3f0d" },
      "autoUpdate": false
    }
  },
  "enabledPlugins": {
    "agile-workflow@nklisch-skills": true,
    "agentic-research@nklisch-skills": true
  },
  "permissions": {
    "deny": [
      "Read(.env*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(**/.ssh/**)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(secrets/**)",
      "Read(credentials/**)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(sudo *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)"
    ]
  }
}
