{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "deny": [
      "Read(.env*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(**/.ssh/**)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(secrets/**)",
      "Read(credentials/**)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(sudo *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)"
    ]
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {}
}
