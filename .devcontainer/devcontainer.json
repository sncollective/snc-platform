{
  "name": "SNC Platform",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },

  "mounts": [
    "source=${localEnv:HOME}/.claude-devcontainer/.claude.json,target=/home/vscode/.claude.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude-devcontainer/.claude,target=/home/vscode/.claude,type=bind,consistency=cached"
  ],

  "onCreateCommand": "sudo update-alternatives --set iptables /usr/sbin/iptables-nft && sudo update-alternatives --set ip6tables /usr/sbin/ip6tables-nft && (sudo pkill dockerd 2>/dev/null; while pgrep -x dockerd >/dev/null; do sleep 0.5; done; sudo rm -f /var/run/docker.pid; sudo service docker start)",
  "postCreateCommand": "sudo apt-get update -qq && sudo apt-get install -y -qq ffmpeg caddy && npm install -g pm2 bun@1.3.12 && bun install && bash scripts/dev/ensure-env.sh && pip install --user pre-commit && (git rev-parse --git-dir >/dev/null 2>&1 && python3 -m pre_commit install || echo 'pre-commit install skipped: no usable git dir — workspace was opened from a submodule checkout, whose .git file points outside the mount. Dev works; commit from the enclosing checkout, or clone standalone for full git function.')",
  "postStartCommand": "bash scripts/dev/start-dev.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "usernamehw.errorlens",
        "ms-azuretools.vscode-docker",
        "anthropic.claude-code"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },

  "forwardPorts": [
    3000, 3001, 3002, 3080, 3082, 1935, 1936, 3900, 8025, 8081, 8888
  ],
  "portsAttributes": {
    "3000": { "label": "API", "onAutoForward": "notify" },
    "3001": { "label": "Web", "onAutoForward": "notify" },
    "3002": { "label": "Web (Staging)", "onAutoForward": "notify" },
    "3080": { "label": "Caddy (Dev)", "onAutoForward": "notify" },
    "3082": { "label": "Caddy (Staging)", "onAutoForward": "notify" },
    "1935": { "label": "SRS RTMP", "onAutoForward": "notify" },
    "1936": { "label": "Liquidsoap RTMP In", "onAutoForward": "ignore" },
    "3900": { "label": "Garage S3", "onAutoForward": "ignore" },
    "8025": { "label": "Mailpit Inbox", "onAutoForward": "notify" },
    "8081": { "label": "imgproxy", "onAutoForward": "ignore" },
    "8888": { "label": "Liquidsoap Harbor", "onAutoForward": "ignore" }
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  },

  "remoteUser": "vscode"
}
