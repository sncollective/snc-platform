# Platform environment — copy to platform/.env and edit as needed.
#
# Bootstrap: `cp platform/.env.example platform/.env` is sufficient for the
# default dev stack. The devcontainer's postCreate does this automatically
# on first build.
#
# Hostname model: code outside the docker network (pm2 API/web on the dev
# host, drizzle-kit, ad-hoc bun shells) reaches services via localhost +
# the published port. Docker service names (snc-postgres, snc-garage, …)
# only resolve from inside the docker network — only LIQUIDSOAP_RTMP_URL
# uses that form by default.
#
# Schema source of truth: apps/api/src/config.ts (ENV_SCHEMA).

# ── Required ──

DATABASE_URL=postgres://snc:snc@localhost:5432/snc
BETTER_AUTH_SECRET=         # min 32 chars — generate with: openssl rand -base64 32

# ── Core (defaulted in config.ts — uncomment to override) ──

# PORT=3000
# LOG_LEVEL=info              # fatal | error | warn | info | debug | trace
# CORS_ORIGIN=http://localhost:3080
# BETTER_AUTH_URL=http://localhost:3080

# ── Storage ──

STORAGE_TYPE=s3               # local (./uploads) or s3 (Garage in dev, real S3 in prod)
# STORAGE_LOCAL_DIR=./uploads

# ── S3 / Garage (required when STORAGE_TYPE=s3) ──
# Deterministic dev fixtures — the key IDs below are imported into Garage on
# first boot via the dev-bootstrap tooling. Garage in dev only listens on
# localhost; rotate if exposed beyond.

S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_BUCKET=snc-storage
S3_ACCESS_KEY_ID=GKdeadbeefdeadbeefdeadbeef
S3_SECRET_ACCESS_KEY=deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

# Garage read-only credentials passed to the imgproxy container by docker-compose.
# Same deterministic import as above; matches init-garage.sh.
GARAGE_IMGPROXY_ACCESS_KEY=GKfeedfacefeedfacefeedface
GARAGE_IMGPROXY_SECRET_KEY=feedfacefeedfacefeedfacefeedfacefeedfacefeedfacefeedfacefeedface

# ── imgproxy (optional — image proxy disabled when IMGPROXY_URL absent) ──

# IMGPROXY_URL=http://localhost:8081
# IMGPROXY_KEY=               # hex-encoded HMAC key
# IMGPROXY_SALT=              # hex-encoded HMAC salt

# ── Streaming — SRS + Liquidsoap (full e2e dev defaults) ──
# Comment SRS_API_URL out to disable streaming entirely (API returns 503).
# Dev secrets below are stable placeholders — rotate for staging/prod.

SRS_API_URL=http://localhost:1985
SRS_HLS_URL=http://localhost:3080/live
PLAYOUT_STREAM_KEY=dev-playout-stream-key
SRS_CALLBACK_SECRET=dev-srs-callback-secret-not-for-production-32
PLAYOUT_CALLBACK_SECRET=dev-playout-callback-secret-not-for-production-32
# SRS_RTMP_HOST=              # only set for non-docker SRS

LIQUIDSOAP_API_URL=http://localhost:8888
# LIQUIDSOAP_RTMP_URL is returned to the streaming UI as a push target, so it
# must be reachable from outside the docker network. host.docker.internal works
# for Docker Desktop and devcontainers; on plain Linux you may need localhost
# or the host's LAN IP. The default (rtmp://snc-liquidsoap:1936/live/stream)
# is the docker-network form and only works for container-to-container pushes.
LIQUIDSOAP_RTMP_URL=rtmp://host.docker.internal:1936/live/stream
# LIQUIDSOAP_CONFIG_DIR=
# LIQUIDSOAP_CALLBACK_HOST=
# LIQUIDSOAP_CALLBACK_PORT=

# ── Media processing (defaulted) ──

# MEDIA_TEMP_DIR=/tmp/snc-media
# MEDIA_FFMPEG_CONCURRENCY=2

# ── Federation (defaulted off) ──

# FEDERATION_DOMAIN=s-nc.org
# FEATURE_FEDERATION=false

# ── Feature flags (default ON — set to "false" to disable a domain) ──

# FEATURE_SUBSCRIPTION=true
# FEATURE_MERCH=true
# FEATURE_BOOKING=true
# FEATURE_EMISSIONS=true

# ── SMTP — Mailpit (dev catcher; inbox at http://localhost:8025) ──
# Mailpit accepts everything and delivers nothing — safe for dev. Override with
# real relay creds for staging/prod. Email features degrade gracefully when
# SMTP_HOST is absent.

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
# EMAIL_FROM=S/NC <noreply@s-nc.org>
# STUDIO_INQUIRY_EMAIL=

# ── Stripe (optional — API returns 503 BILLING_NOT_CONFIGURED when absent) ──

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Shopify (optional — API returns 503 MERCH_NOT_CONFIGURED when absent) ──

# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_STOREFRONT_TOKEN=

# ── Seafile OIDC provider (optional — provider inactive when absent) ──

# SEAFILE_OIDC_CLIENT_ID=
# SEAFILE_OIDC_CLIENT_SECRET= # min 32 chars

# ── Social login providers (all optional) ──

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# MASTODON_REDIRECT_URI=

# ── YouTube streaming connect (separate from Google sign-in) ──

# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
