# S/NC Environment Configuration
# Copy to .env and adjust values for your environment.
# Lines marked (required) will cause the API to crash on startup if missing.

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgres://snc:snc@localhost:5432/snc

# ── Server ────────────────────────────────────────────────
# API server port
PORT=3000

# Allowed CORS origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3001

# ── Authentication ────────────────────────────────────────
# Better Auth secret — min 32 characters (required)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Better Auth base URL (must match the API's public URL)
BETTER_AUTH_URL=http://localhost:3000

# ── Storage ───────────────────────────────────────────────
# Storage backend type (currently only "local" is supported)
STORAGE_TYPE=local

# Directory for uploaded files (created automatically)
STORAGE_LOCAL_DIR=./uploads

# ── Stripe (optional) ─────────────────────────────────────
# Subscription/billing features return 503 when these are not set.
# The rest of the app works fine without them.

# Stripe API secret key
# Get from: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret
# Get from: Stripe Dashboard → Developers → Webhooks → signing secret
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Shopify (optional) ───────────────────────────────────
# Merch features return 503 when these are not set. The rest of the app works fine.

# Shopify store domain (use the .myshopify.com domain)
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Shopify Storefront API access token
# Get from: Shopify Admin → Apps → Develop apps → Storefront API
# SHOPIFY_STOREFRONT_TOKEN=

# ── Feature Flags (frontend only) ─────────────────────────
# Control which sections are visible in the web app.
# Absent or empty = ON (dev default). Set to "false" to disable.
# Production defaults: all off except admin (see apps/web/.env.staging).
#
# To preview production flags locally:
#   pm2 stop web
#   (cd apps/web && npx vite --mode staging)
#
# VITE_FEATURE_CONTENT=true
# VITE_FEATURE_CREATOR=true
# VITE_FEATURE_SUBSCRIPTION=true
# VITE_FEATURE_MERCH=true
# VITE_FEATURE_BOOKING=true
# VITE_FEATURE_DASHBOARD=true
# VITE_FEATURE_ADMIN=true
# VITE_FEATURE_EMISSIONS=true