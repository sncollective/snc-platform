# ── Required ──

DATABASE_URL=postgres://snc:snc@localhost:5432/snc
BETTER_AUTH_SECRET=          # min 32 chars — generate with: openssl rand -base64 32

# ── Optional (sensible defaults) ──

# PORT=3000
# LOG_LEVEL=info             # fatal | error | warn | info | debug | trace
# CORS_ORIGIN=http://localhost:3080
# BETTER_AUTH_URL=http://localhost:3080

# ── Storage ──

# STORAGE_TYPE=local         # local (dev) or s3 (production)
# STORAGE_LOCAL_DIR=./uploads

# S3-compatible storage (required when STORAGE_TYPE=s3)
# S3_ENDPOINT=https://your-s3-endpoint
# S3_REGION=garage
# S3_BUCKET=your-bucket
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# ── Stripe (optional — billing returns 503 when absent) ──

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Shopify (optional — merch returns 503 when absent) ──

# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token

# ── Owncast (optional — streaming returns 503 when absent) ──

# OWNCAST_URL=https://your-owncast-instance

# ── SMTP (optional — email features degrade gracefully) ──

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=S/NC <noreply@s-nc.org>
# STUDIO_INQUIRY_EMAIL=

# ── Seafile OIDC (optional — OIDC provider inactive when absent) ──

# SEAFILE_OIDC_CLIENT_ID=
# SEAFILE_OIDC_CLIENT_SECRET=   # min 32 chars

# ── ActivityPub Federation (off by default) ──

# FEDERATION_DOMAIN=s-nc.org
# FEATURE_FEDERATION=false

# ── Feature Flags (all default true except federation/streaming) ──

# FEATURE_CONTENT=true
# FEATURE_CREATOR=true
# FEATURE_SUBSCRIPTION=true
# FEATURE_MERCH=true
# FEATURE_BOOKING=true
# FEATURE_DASHBOARD=true
# FEATURE_ADMIN=true
# FEATURE_EMISSIONS=true
# FEATURE_CALENDAR=true
# FEATURE_STREAMING=false
