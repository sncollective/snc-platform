http://localhost:3080 {
	handle /api/* {
		reverse_proxy localhost:3000
	}
	handle /health {
		reverse_proxy localhost:3000
	}
	handle /uploads/* {
		reverse_proxy localhost:8070
	}
	@hls {
		path /live/*.m3u8 /live/*.ts
	}
	handle @hls {
		reverse_proxy localhost:8080
	}
	handle {
		reverse_proxy localhost:3001
	}
}

http://localhost:3082 {
	handle /api/* {
		reverse_proxy localhost:3000
	}
	handle /health {
		reverse_proxy localhost:3000
	}
	handle /uploads/* {
		reverse_proxy localhost:8070
	}
	handle {
		reverse_proxy localhost:3002
	}
}

http://localhost:3084 {
	reverse_proxy localhost:4321
}
