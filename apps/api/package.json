{
  "name": "@snc/api",
  "version": "0.1.0",
  "description": "S/NC Hono API backend",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore './uploads/**' --import ./src/env.ts src/index.ts",
    "build": "echo 'API runs via tsx — no build step needed'",
    "start": "node --import tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "db:generate": "node --import tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --import tsx node_modules/drizzle-kit/bin.cjs migrate",
    "seed:admin": "tsx --import ./src/env.ts src/scripts/seed-admin.ts",
    "seed:demo": "ALLOW_DEMO_SEED=true tsx --import ./src/env.ts src/scripts/seed-demo.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@fedify/fedify": "^2.0.5",
    "@fedify/hono": "^2.0.5",
    "@fedify/postgres": "^2.0.5",
    "@hono/node-server": "^1.19.11",
    "@hono/standard-validator": "^0.2.2",
    "@scalar/hono-api-reference": "^0.9.46",
    "@snc/shared": "workspace:*",
    "better-auth": "^1.5.4",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "hono-openapi": "^1.2.0",
    "ical-generator": "^10.0.0",
    "nodemailer": "^8.0.2",
    "postgres": "^3.4.7",
    "stripe": "^20.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^7.0.11",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
