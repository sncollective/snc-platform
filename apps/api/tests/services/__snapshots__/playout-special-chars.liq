# ── Auto-generated by S/NC Platform ──
# Do not edit manually — regenerated on channel create/delete.
# Static sections (logging, S3, encoding, health, S/NC TV) are preserved.

# ── Logging ──

log.stdout := true
log.file := false
log.level := 4

# ── S3 Protocol (Garage) ──

settings.protocol.aws.endpoint := environment.get("AWS_ENDPOINT", default="http://snc-garage:3900")
settings.protocol.aws.region := environment.get("AWS_DEFAULT_REGION", default="garage")

# ── Config ──

playout_key = environment.get("PLAYOUT_STREAM_KEY", default="")
srs_host = environment.get("SRS_RTMP_HOST", default="snc-srs")
api_host = environment.get("API_CALLBACK_HOST", default="snc-api")
api_port = environment.get("API_CALLBACK_PORT", default="3000")
callback_secret = environment.get("PLAYOUT_CALLBACK_SECRET", default="")

# ── Encoding ──

enc = %ffmpeg(
  format="flv",
  %video(codec="libx264", preset="ultrafast", b="2500k", g="60"),
  %audio(codec="aac", b="256k")
)

settings.harbor.bind_addrs := ["0.0.0.0"]

# ── Health Check ──

harbor.http.register(port=8888, method="GET", "/health", fun(_req, res) -> begin
  res.data("ok")
end)

# ── Admin Control ──

harbor.http.register(port=8888, method="POST", "/admin/shutdown", fun(req, res) -> begin
  secret = environment.get("PLAYOUT_CALLBACK_SECRET", default="")
  q = req.query
  if q["secret"] == secret and secret != "" then
    res.data("shutting down")
    shutdown()
  else
    res.status_code(401)
    res.data("unauthorized")
  end
end)

# ── Channels (generated from database — playout + S/NC TV broadcast) ──

# ── Channel: Channel \"Special\" \\ Test (playout) ──

ch_aaaaaaaa_0000_0000_0000_000000000001_queue = request.queue(id="channel-aaaaaaaa-0000-0000-0000-000000000001")
ch_aaaaaaaa_0000_0000_0000_000000000001_pool = request.dynamic(fun() -> begin
  uri = http.get("http://#{api_host}:#{api_port}/api/playout/channels/aaaaaaaa-0000-0000-0000-000000000001/pool/next?secret=#{callback_secret}")
  if uri == "" then null() else request.create(uri) end
end)
ch_aaaaaaaa_0000_0000_0000_000000000001_queue_program = fallback(track_sensitive=true, [ch_aaaaaaaa_0000_0000_0000_000000000001_queue, ch_aaaaaaaa_0000_0000_0000_000000000001_pool])

ch_aaaaaaaa_0000_0000_0000_000000000001_armed = ref(true)

ch_aaaaaaaa_0000_0000_0000_000000000001_source = switch(track_sensitive=false, [
  ({ ch_aaaaaaaa_0000_0000_0000_000000000001_armed() }, ch_aaaaaaaa_0000_0000_0000_000000000001_queue_program),
  ({ true }, mksafe(blank()))
])

ch_aaaaaaaa_0000_0000_0000_000000000001_uri = ref("")
ch_aaaaaaaa_0000_0000_0000_000000000001_title = ref("")
ch_aaaaaaaa_0000_0000_0000_000000000001_queue.on_metadata(synchronous=false, fun(m) -> begin
  u = m["s3_uri"]
  ch_aaaaaaaa_0000_0000_0000_000000000001_uri := if u == "" then m["filename"] else u end
  ch_aaaaaaaa_0000_0000_0000_000000000001_title := m["title"]
  ignore(http.post(
    headers=[("Content-Type", "application/json")],
    data='{"uri":"#{ch_aaaaaaaa_0000_0000_0000_000000000001_uri()}","title":"#{ch_aaaaaaaa_0000_0000_0000_000000000001_title()}"}',
    "http://#{api_host}:#{api_port}/api/playout/channels/aaaaaaaa-0000-0000-0000-000000000001/track-event?secret=#{callback_secret}"
  ))
end)

output.url(url="rtmp://#{srs_host}:1935/live/channel-special?key=#{playout_key}", enc, ch_aaaaaaaa_0000_0000_0000_000000000001_source)

harbor.http.register(port=8888, method="POST", "/channels/aaaaaaaa-0000-0000-0000-000000000001/queue", fun(req, res) -> begin
  secret = environment.get("PLAYOUT_CALLBACK_SECRET", default="")
  q = req.query
  if q["secret"] == secret and secret != "" then
    ch_aaaaaaaa_0000_0000_0000_000000000001_queue.push.uri(req.body())
    res.data("queued")
