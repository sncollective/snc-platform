# S/NC Production Caddyfile
#
# Shared snippets + site blocks for s-nc.org and s-nc.tv.
# Other service blocks (storage, streaming) are in their deploy guides:
#   docs/ops/garage-deploy.md         → storage.s-nc.org
#   docs/ops/srs-deploy.md           → stream.s-nc.tv (SRS)
#
# Replace APP_IP with the snc-app container IP.
# Replace TUSD_IP with the tusd host:port (the snc-tusd service — see
# snc-tusd.service.example). Resumable uploads are served by tusd, NOT the API,
# so /uploads/* must route there, not to APP_IP. If tusd is co-located with the
# app, this is the host's own address on tusd's published port (e.g. :8070).
#
# ⚠ Do NOT add an `encode` (compression) directive without exempting /api/sse —
# Hono streamSSE can only send Cache-Control: no-cache (no no-transform), so a
# compression layer would buffer the event stream and break it silently.
# Replace SRS_IP with the SRS container/LXC IP (only used in s-nc.tv block).
#
# Internal services (Garage admin :3903, SRS API :1985, Grafana :3000)
# are NOT proxied here — they are internal VLAN only.

# ── Global options ───────────────────────────────────────────────
{
	# Explicit TLS policy — Caddy defaults are strong, making them
	# explicit prevents surprises on upgrades.
	default_sni s-nc.org
}

# ── Shared security headers ──────────────────────────────────────
# Import in every site block: `import security_headers`
(security_headers) {
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}
}

# ── Shared access logging ────────────────────────────────────────
# Structured JSON access logs. Caddy runs under systemd, so logs
# also appear in the journal. File output lets Promtail ship to Loki
# without relying on journal parsing for HTTP access data.
(access_log) {
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 5
		}
		format json
	}
}

# ── Platform (s-nc.org) ───────────────────────────────────────────
s-nc.org {
	import security_headers
	import access_log

	# TLS — Caddy auto-provisions Let's Encrypt certs.
	# Explicit protocol range for defense-in-depth.
	tls {
		protocols tls1.2 tls1.3
	}

	# Request body limit — 10MB covers API JSON + multipart forms.
	# Large media uploads go direct to S3 via presigned URLs (bypass Caddy).
	request_body {
		max_size 10MB
	}

	# API + health → API server
	handle /api/* {
		reverse_proxy APP_IP:3000
	}
	handle /health {
		reverse_proxy APP_IP:3000
	}

	# Resumable uploads → tusd (NOT the API — the API has no /uploads/* route).
	# tusd serves the tus protocol at -base-path=/uploads/; it calls back to
	# APP_IP:3000/api/tusd/hooks on finish. Body limit must not clip tus chunk
	# PATCHes, so exempt this path from the 10MB request_body cap above.
	handle /uploads/* {
		request_body {
			max_size 20GB
		}
		reverse_proxy TUSD_IP:8070
	}

	# Everything else → Web SSR server
	handle {
		reverse_proxy APP_IP:3001
	}

	# Graceful fallback when upstream is down
	handle_errors {
		respond {err.status_code}
	}
}

# ── Streaming site (s-nc.tv) ─────────────────────────────────────
# Same app as s-nc.org, different domain entry point.
# HLS segments are proxied from SRS (port 8080) via path matcher.
s-nc.tv {
	import security_headers
	import access_log

	tls {
		protocols tls1.2 tls1.3
	}

	request_body {
		max_size 10MB
	}

	handle /api/* {
		reverse_proxy APP_IP:3000
	}
	handle /health {
		reverse_proxy APP_IP:3000
	}

	# Resumable uploads → tusd (NOT the API — the API has no /uploads/* route).
	# tusd serves the tus protocol at -base-path=/uploads/; it calls back to
	# APP_IP:3000/api/tusd/hooks on finish. Body limit must not clip tus chunk
	# PATCHes, so exempt this path from the 10MB request_body cap above.
	handle /uploads/* {
		request_body {
			max_size 20GB
		}
		reverse_proxy TUSD_IP:8070
	}

	# SRS HLS — .m3u8 playlists and .ts segments
	@hls {
		path /live/*.m3u8 /live/*.ts
	}
	handle @hls {
		reverse_proxy SRS_IP:8080
	}

	handle {
		reverse_proxy APP_IP:3001
	}

	handle_errors {
		respond {err.status_code}
	}
}
