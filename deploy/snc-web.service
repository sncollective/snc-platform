[Unit]
Description=S/NC Web SSR Server
After=snc-api.service

[Service]
Type=simple
User=snc
Group=snc
WorkingDirectory=/opt/snc/platform/apps/web
EnvironmentFile=/opt/snc/platform/.env
Environment=PORT=3001 NITRO_PORT=3001
ExecStart=/usr/bin/node .output/server/index.mjs
Restart=on-failure
RestartSec=5


[Install]
WantedBy=multi-user.target
