{
  "name": "snc",
  "version": "0.1.0",
  "description": "S/NC — Worker-cooperative content publishing platform",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://code.s-nc.org/sncollective/snc-platform.git"
  },
  "homepage": "https://s-nc.org",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @snc/api dev & pnpm --filter @snc/web dev",
    "start": "docker compose up -d --wait && pnpm install --frozen-lockfile && pnpm --filter @snc/api db:migrate && pnpm dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "hono": "^4.12.8"
    }
  }
}
